# === 阿里云 RDS 数据库 ===
DATABASE_URL=postgresql://用户名:密码@主机:5432/数据库名

# === 钉钉扫码登录 (DingTalk OAuth) ===
DINGTALK_APP_KEY=你的钉钉应用AppKey
DINGTALK_APP_SECRET=你的钉钉应用AppSecret
DINGTALK_CALLBACK_URL=https://你的ngrok域名/api/auth/dingtalk-callback

# === 飞书日历 (Feishu OAuth) ===
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=你的飞书应用AppSecret
FEISHU_CALLBACK_URL=https://你的ngrok域名/api/auth/feishu-callback

# === 阿里云 OSS 相册存储 ===
OSS_REGION=oss-cn-beijing
OSS_BUCKET=framene-photos
OSS_ACCESS_KEY_ID=RAM子账号AccessKey
OSS_ACCESS_KEY_SECRET=RAM子账号AccessSecret

# === 阿里云主AccessKey（部分功能，如非必须可留空）===
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# === 前端地址（用于CORS和回调）===
APP_URL=http://localhost:8080

# === 邮件发送 ===
EMAIL_SENDER_ADDRESS=noreply@send.framene.com
