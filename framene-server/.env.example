# ====== FrameNe 后端配置模板 ======
# 复制为 .env 文件，填入实际值
#
# 本地开发：放在 framene-server 目录下
# FC 部署：在 FC 控制台以环境变量的方式配置（不要上传 .env 到部署包）

# 阿里云 AccessKey（用于短信和邮件）
# 建议使用 RAM 子账号，最低权限：短信 dysms、邮件推送 dm、OSS
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret

# RDS PostgreSQL 数据库
DATABASE_URL=postgresql://user:password@host:5432/dbname

# 邮件推送（邮箱验证码）
EMAIL_SENDER_ADDRESS=noreply@send.framene.com

# === 语音 Pipeline API Key（framene_v1_1 → 后端鉴权）===
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VOICE_API_KEY=

# 短信服务（手机验证码 - 可选）
SMS_SIGN_NAME=FrameNe
SMS_TEMPLATE_CODE=SMS_123456789

# JWT 密钥
JWT_SECRET=your-jwt-secret-change-in-production

# 钉钉扫码登录
DINGTALK_APP_KEY=your_dingtalk_app_key
DINGTALK_APP_SECRET=your_dingtalk_app_secret
DINGTALK_CALLBACK_URL=https://your-domain/api/auth/dingtalk-callback

# 前端地址（OAuth 回调后重定向）
APP_URL=https://www.framene.com

# OSS 照片存储（阿里云 OSS）
OSS_REGION=oss-cn-beijing
OSS_BUCKET=framene-photos
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret

# 飞书日历应用
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_CALLBACK_URL=https://your-domain/api/auth/feishu-callback
