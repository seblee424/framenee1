# =============================================
# FrameNe Web 端环境变量配置指南
# =============================================
# 说明：
# 本文件是示例模板，复制为 .env 后填入真实值即可。
# cp .env.example .env
#
# 注意：
# - .env 文件不要提交到 Git（已在 .gitignore 中排除）
# - 启动前端前确保后端（Express）已在目标地址运行
# - 部署到不同环境只需修改此文件
# =============================================

# 后端 API 地址
# 开发环境（本地）：http://localhost:3000
# 测试环境（ngrok）：https://xxxx.ngrok-free.dev
# 生产环境（FC）：https://framene-api.your-domain.com
VITE_API_BASE_URL=http://localhost:3000

# 可选：默认用户邮箱（用于筛选照片等数据）
# 如不填写，照片列表会显示所有用户的照片
# VITE_OWNER_EMAIL=your-email@example.com
