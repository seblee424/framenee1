# FrameNe 环境变量配置
# 复制此文件为 .env 并填入你的配置

# Supabase 项目配置（必填）
# 在 Supabase Dashboard → Settings → API 中找到
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# Supabase Service Role Key（仅用于管理后台，不要放在前端代码中）
# 在 Supabase Dashboard → Settings → API → service_role key
# 注意：这个 key 有完全访问权限，永远不要暴露给客户端
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Google OAuth 配置
# 在 Supabase Dashboard → Authentication → Providers → Google 中配置
# 需要先在 Google Cloud Console 创建 OAuth 2.0 凭据
# 授权重定向 URI 格式: https://<your-project-ref>.supabase.co/auth/v1/callback
# 需要启用的 Google API:
#   - Google Calendar API
# OAuth 范围:
#   - https://www.googleapis.com/auth/calendar.readonly
